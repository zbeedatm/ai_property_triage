# WebUI — Docker environment variables
# Copy to docker/secrets/webui.env (docker/secrets/ is gitignored).

# Ollama Cloud (default): create an API key at https://ollama.com/settings/keys
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b

# Local Ollama instead: OLLAMA_HOST=http://host.docker.internal:11434 (or http://ollama:11434 if you run a local ollama container) and omit OLLAMA_API_KEY.

FILE_BASE_URL=http://webui:7860

N8N_WEBHOOK_URL=http://n8n:5678/webhook/property-triage

APP_TITLE=Property Triage Platform
PORT=7860
HOST=0.0.0.0
GRADIO_SERVER_NAME=0.0.0.0

HTTP_TIMEOUT=120
