# Layer 3 — LangGraph agent
# Copy to .env in this directory:  cp .env.example .env
# (main.py and agent.py load .env from this folder)

# --- Planner / synthesiser LLM ---
LLM_PROVIDER=gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# LLM_PROVIDER=local  → local Ollama
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=mistral

# --- Which RAG service to call ---
RAG_BACKEND=pinecone
RAG_PINECONE_URL=http://127.0.0.1:8001
# RAG_BACKEND=chroma
# RAG_CHROMA_URL=http://127.0.0.1:8001

RAG_SERVICE_URL=
IMAGE_SERVICE_URL=http://127.0.0.1:8002
HTTP_TIMEOUT=600
