      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: true, channel: 'residential', report: $('Node 6 \u2014 Final Report LLM Chain').item.json }) }}",
        "options": {
          "responseCode": 200
        }
      }
    },
    {
      "id": "node-8b-commercial-respond",
      "name": "Node 8b \u2014 Commercial Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        2260,
