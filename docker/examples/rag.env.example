# RAG Service (Pinecone) — Docker environment variables
# Copy to docker/secrets/rag.env and fill in secrets (docker/secrets/ is gitignored).

# Pinecone API key (required — get yours at https://app.pinecone.io)
PINECONE_API_KEY=

# Pinecone index name
PINECONE_INDEX_NAME=property-listings

# Pinecone cloud and region for serverless index creation
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Path to the GGUF model file (mounted volume inside the container)
MODEL_PATH=/app/models/mistral-7b-instruct-v0.2.Q4_K_M.gguf

# HuggingFace sentence-transformer model for embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Number of similar listings to retrieve
TOP_K=3

# Skip local LLM (Mistral 7B) insight generation — return retrieval results only.
SKIP_LLM=false
