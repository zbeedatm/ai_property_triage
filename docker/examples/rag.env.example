# RAG Service (Pinecone) — Docker environment variables
# Copy to docker/secrets/rag.env and fill in secrets (docker/secrets/ is gitignored).

# Pinecone API key (required — get yours at https://app.pinecone.io)
PINECONE_API_KEY=

# Pinecone index name
PINECONE_INDEX_NAME=property-listings

# Pinecone cloud and region for serverless index creation
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# HuggingFace sentence-transformer model for embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Number of similar listings to retrieve
TOP_K=3

# --- Insight LLM (after retrieval) ---
# ollama (default): Ollama Cloud or local Ollama HTTP API
RAG_LLM_BACKEND=ollama
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b

# Legacy: run Mistral GGUF inside the container (set RAG_LLM_BACKEND=llama_cpp and mount ./models)
# RAG_LLM_BACKEND=llama_cpp
# MODEL_PATH=/app/models/mistral-7b-instruct-v0.2.Q4_K_M.gguf
# RAG_LLM_THREADS=2
