# Layer 3 — Guardrails
# Copy to .env in this directory:  cp .env.example .env

GOOGLE_API_KEY=

# NeMo / LangChain OpenAI-compatible route to Gemini
OPENAI_API_KEY=
OPENAI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai

GUARDRAILS_MODEL=gemini-2.5-flash
GUARDRAILS_MAX_OUTPUT_TOKENS=2048

# Rails config (Docker default; override for local paths if needed)
RAILS_CONFIG_PATH=/app/rails
