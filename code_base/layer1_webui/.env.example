# Layer 1 — WebUI (Gradio)
# Copy to .env:  cp .env.example .env

# Ollama server (must be running separately — not in Docker)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=mistral

# --- Ollama (chat) — Cloud or local ---
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b

# Local Ollama: OLLAMA_HOST=http://localhost:11434  (leave OLLAMA_API_KEY empty)

# --- n8n listing submission ---
N8N_WEBHOOK_URL=http://localhost:5678/webhook/property-triage
HTTP_TIMEOUT=120

# --- Gradio / uploads ---
APP_TITLE=Property Triage Platform
PORT=7860
HOST=0.0.0.0
# Optional: temporary public URL via Gradio (set to 1 only if you want that)
# GRADIO_SHARE=0
GRADIO_SERVER_NAME=0.0.0.0
FILE_BASE_URL=http://127.0.0.1:7860
