# Guardrails Service — Docker environment variables
# Copy to docker/secrets/guardrails.env and fill in secrets (docker/secrets/ is gitignored).

# Google API key (used by the custom action classifiers in actions.py)
GOOGLE_API_KEY=

# NeMo Guardrails uses LangChain's ChatOpenAI pointing to Google's
# OpenAI-compatible endpoint via these env vars
OPENAI_API_KEY=
OPENAI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai

# Model used for guardrail classification calls
GUARDRAILS_MODEL=gemini-2.5-flash

# Path to the rails config directory (inside the container)
RAILS_CONFIG_PATH=/app/rails
