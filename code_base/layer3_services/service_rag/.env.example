# Layer 3 — RAG (Pinecone)
# Copy to .env in this directory:  cp .env.example .env

# --- Pinecone ---
PINECONE_API_KEY=
PINECONE_INDEX_NAME=property-listings
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TOP_K=3
RAG_AUTO_SEED=true

# --- Insight LLM: ollama (default) or llama_cpp ---
RAG_LLM_BACKEND=ollama
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b

# Legacy GGUF (only when RAG_LLM_BACKEND=llama_cpp)
# MODEL_PATH=../../../models/mistral-7b-instruct-v0.2.Q4_K_M.gguf
# RAG_LLM_THREADS=2
