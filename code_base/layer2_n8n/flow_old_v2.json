      ],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: true, channel: 'commercial', report: $('Node 6 \u2014 Final Report LLM Chain').item.json }) }}",
        "options": {
          "responseCode": 200
        }
      }
    }
