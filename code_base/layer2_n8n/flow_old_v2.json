        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "report",
              "value": "={{ JSON.stringify($('Node 6 \u2014 Final Report LLM Chain').item.json) }}"
            },
            {
              "name": "flag_reason",
              "value": "={{ $('Node 7 \u2014 Guardrails Output Check').item.json.reason }}"
            },
            {
              "name": "agent_name",
              "value": "={{ $('Node 1 \u2014 Webhook Trigger').item.json.body.agent_name }}"
            }
          ]
        },
        "options": {
          "timeout": 15000
        }
      }
    },
    {
      "id": "node-8-property-router",
      "name": "Node 8 \u2014 Property Type Router",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        2020,
        300
      ],
      "parameters": {
        "rules": {
          "values": [
            {
              "outputKey": "residential",
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $('Node 6 \u2014 Final Report LLM Chain').item.json.routing_decision }}",
                    "rightValue": "residential",
                    "operator": {
                      "type": "string",
                      "operation": "equals",
                      "name": "filter.operator.equals"
                    }
                  }
                ],
                "combinator": "and"
              }
            },
            {
              "outputKey": "commercial",
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $('Node 6 \u2014 Final Report LLM Chain').item.json.routing_decision }}",
                    "rightValue": "commercial",
                    "operator": {
                      "type": "string",
                      "operation": "equals",
                      "name": "filter.operator.equals"
                    }
                  }
                ],
                "combinator": "and"
              }
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      }
    },
    {
      "id": "node-8a-residential-respond",
      "name": "Node 8a \u2014 Residential Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        2260,
