# LangGraph Agent Service — Docker environment variables
# Copy to docker/secrets/langgraph.env and fill in secrets (docker/secrets/ is gitignored).

# LLM backend: "gemini" | "openai" | "local"
LLM_PROVIDER=gemini

# Google Gemini API
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# # OpenAI settings (used when LLM_PROVIDER=openai)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Local LLM server URL (used when LLM_PROVIDER=local)
# LOCAL_LLM_URL=http://host.docker.internal:8080/v1

# RAG backend selector: "pinecone" (service_rag) or "chroma" (service_rag_chroma)
RAG_BACKEND=pinecone

# Sibling service URLs — Docker network names (container:internal_port)
RAG_PINECONE_URL=http://rag:8000
# RAG_CHROMA_URL=http://rag_chroma:8000
IMAGE_SERVICE_URL=http://image_analyser:8000

# HTTP timeout in seconds for calls to sibling services
HTTP_TIMEOUT=600
